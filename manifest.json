{
  "manifest_version": 3,
  "name": "TrimLoop",
  "version": "1.0",
  "description": "Loop a section of any video.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}