{
  "$schema": "https://json.schemastore.org/chrome-manifest",
  "manifest_version": 3,
  "name": "TrimLoop",
  "version": "1.0",
  "description": "Loop a section of any video.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": { "16": "icons/icon.png" }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "set-start": {
      "suggested_key": { "default": "Ctrl+Down", "mac": "Command+Down" },
      "description": "Set loop start"
    },
    "set-end": {
      "suggested_key": { "default": "Ctrl+Up", "mac": "Command+Up" },
      "description": "Set loop end"
    },
    "toggle-loop": {
      "suggested_key": { "default": "Ctrl+Shift+Up", "mac": "Command+Shift+Up" },
      "description": "Toggle video loop"
    },

    "reset-loop-bounds": {
      "suggested_key": { "default": "Ctrl+Shift+Down", "mac": "Command+Shift+Down" },
      "description": "Reset loop bounds"
    }  
  }
}